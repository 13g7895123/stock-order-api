# 富邦 Neo API 登入資訊
# ------------------------------------------------
# 複製為 .env 後填入，.env 不進 Git。
# 詳見 docs/fubon-credentials-guide.md

FUBON_PERSONAL_ID=A123456789
FUBON_PASSWORD=your_login_password
FUBON_CERT_PATH=secrets/A123456789.pfx
FUBON_CERT_PASSWORD=your_cert_password
FUBON_BRANCH_NO=6460
FUBON_ACCOUNT_NO=1234567

# 可選：API Key 登入
# - 只填 FUBON_API_KEY → 走 apikey_login（新版，不需 Secret Key）
# - FUBON_API_KEY + FUBON_API_SECRET 同時填 → 走舊版六參數 login
# - 兩者皆空 → 走純憑證登入（仍可完整使用帳務查詢）
# 啟用 API Key 記得至後台設定 IP 白名單。
# FUBON_API_KEY=
# FUBON_API_SECRET=

# 連線
FUBON_TIMEOUT_SEC=30
FUBON_RECONNECT_TIMES=2

# 執行模式
FUBON_DRY_RUN=false

# ==== 即時行情（WebSocket）====
# 模式：speed = 低延遲聚合；normal = 完整欄位（支援 candles / aggregates）
FUBON_REALTIME_MODE=speed
# 斷線重連：連續失敗次數上限
FUBON_REALTIME_RECONNECT_MAX=5
# 指數退避起始秒數（實際最多 max_sec）
FUBON_REALTIME_RECONNECT_BASE_SEC=2
FUBON_REALTIME_RECONNECT_MAX_SEC=60
# 每檔商品保留幾筆 tick（記憶體 ring buffer）
FUBON_REALTIME_RING_BUFFER=500
# 每 N 秒寫一筆 STATS（msg/s、p50/p95 延遲）
FUBON_REALTIME_STATS_INTERVAL=10
